# Generate both with: openssl rand -hex 32
GAME_SECRET=replace-with-a-long-random-secret
CLAIM_SECRET=replace-with-a-second-long-random-secret

# Strongly recommended for Vercel production so runs cannot be replayed across serverless instances.
# Vercel KV / Upstash-style names are both supported by src/lib/game/store.ts.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
